<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="easyONBOARDING - Create New Employee (AD User)"
    Width="1225"
    Height="800">
    <!--  Hauptcontainer: Grid, der den TabControl-Bereich umschließt  -->
    <Grid Margin="0,0,0,37">
        <!--  TabControl mit allen Hauptfunktionen  -->
        <TabControl x:Name="MainTabControl" Margin="10,10,10,-28">
            <!--  TAB 1: easyONBOARDING  -->
            <TabItem x:Name="Tab_Onboarding" Header="easyONBOARDING">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <!--  Linkes Panel  -->
                        <ColumnDefinition Width="420" />
                        <!--  Mittleres Panel (eindeutige Namen mit Suffix _Onb)  -->
                        <ColumnDefinition Width="450" />
                        <!--  Rechtes Panel (eindeutige Namen mit Suffix _Onb2)  -->
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="700" />
                    </Grid.RowDefinitions>

                    <!--  Linkes Panel: Eingabeformular für Onboarding-Daten  -->
                    <Border
                        Grid.Column="0"
                        Margin="0,0,10,10"
                        Background="WhiteSmoke"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        CornerRadius="5">
                        <StackPanel Margin="5,5,5,-9">
                            <!--  OU Auswahl und Refresh  -->
                            <Grid Margin="5" Background="#FFFFF6E9">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="328.38" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Select OU:" />
                                <ComboBox
                                    x:Name="cmbOU"
                                    Grid.Column="1"
                                    MinWidth="200"
                                    Margin="47,0,56,0"
                                    VerticalAlignment="Center" />
                                <Button
                                    x:Name="btnRefreshOU"
                                    Grid.Column="1"
                                    Height="25"
                                    Margin="280,0,0,0"
                                    Content="Refresh" />
                            </Grid>
                            <!--  First Name  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="First Name *:" />
                                <TextBox
                                    x:Name="txtFirstName"
                                    Grid.Column="1"
                                    Width="281"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Right" />
                            </Grid>
                            <!--  Last Name  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Last Name *:" />
                                <TextBox
                                    x:Name="txtLastName"
                                    Grid.Column="1"
                                    Width="281"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Right" />
                            </Grid>
                            <!--  External Employee Checkbox  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="External Employee:" />
                                <CheckBox
                                    x:Name="chkExternal"
                                    Grid.Column="1"
                                    Margin="2,0,0,0"
                                    VerticalAlignment="Center" />
                            </Grid>
                            <Separator Margin="5" />
                            <!--  Display Name  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Display Name:" />
                                <TextBox
                                    x:Name="txtDisplayName"
                                    Grid.Column="1"
                                    Width="281"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Right" />
                            </Grid>
                            <!--  UPN Template Auswahl  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Template:" />
                                <ComboBox
                                    x:Name="cmbDisplayTemplate"
                                    Grid.Column="1"
                                    MinWidth="200"
                                    Margin="51,0,0,0"
                                    VerticalAlignment="Center">
                                    <ComboBoxItem Content="Template1" />
                                    <ComboBoxItem Content="Template2" />
                                </ComboBox>
                            </Grid>
                            <!--  Description  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Description:" />
                                <TextBox
                                    x:Name="txtDescription"
                                    Grid.Column="1"
                                    Width="281"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Right" />
                            </Grid>
                            <!--  Office  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Office:" />
                                <TextBox
                                    x:Name="txtOffice"
                                    Grid.Column="1"
                                    Width="281"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Right" />
                            </Grid>
                            <!--  Phone  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Phone:" />
                                <TextBox
                                    x:Name="txtPhone"
                                    Grid.Column="1"
                                    Width="281"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Right" />
                            </Grid>
                            <!--  Mobile  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Mobile:" />
                                <TextBox
                                    x:Name="txtMobile"
                                    Grid.Column="1"
                                    Width="280"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Right" />
                            </Grid>
                            <!--  Position  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Position:" />
                                <TextBox
                                    x:Name="txtPosition"
                                    Grid.Column="1"
                                    Width="280"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Right" />
                            </Grid>
                            <!--  Department  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Department:" />
                                <TextBox
                                    x:Name="txtDepartment"
                                    Grid.Column="1"
                                    Width="280"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Right" />
                            </Grid>
                            <!--  Termination Date  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Termination Date:" />
                                <TextBox
                                    x:Name="txtTermination"
                                    Grid.Column="1"
                                    Width="280"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Right" />
                            </Grid>
                            <!--  Hinweis  -->
                            <Border Height="20" Background="Transparent">
                                <TextBlock
                                    Width="268"
                                    Margin="103,-3,5,7"
                                    FontStyle="Italic"
                                    Text="Not effective when disabled!" />
                            </Border>
                            <!--  Location Auswahl  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Location *:" />
                                <ComboBox
                                    x:Name="cmbLocation"
                                    Grid.Column="1"
                                    Width="280"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="Bez"
                                    ItemsSource="{Binding LocationListFromINI}"
                                    SelectedValuePath="Key" />
                            </Grid>
                            <!--  MS365 License Auswahl  -->
                            <TextBlock
                                Margin="0,5"
                                HorizontalAlignment="Center"
                                Text="-" />
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="MS365 License *:" />
                                <ComboBox
                                    x:Name="cmbLicense"
                                    Grid.Column="1"
                                    Width="280"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{Binding LicenseListFromINI}"
                                    SelectedValuePath="Value" />
                            </Grid>
                            <Border Height="126" Background="Transparent" />
                            <!--  Team Leader & Department Head Einstellungen  -->
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox
                                    x:Name="chkTL"
                                    Grid.Column="0"
                                    Margin="108,0,10,0"
                                    VerticalAlignment="Center"
                                    Content="Team Leader (TL)" />
                                <CheckBox
                                    x:Name="chkAL"
                                    Grid.Column="1"
                                    Margin="23,0,10,0"
                                    VerticalAlignment="Center"
                                    Content="Department Head (AL)" />
                            </Grid>
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="TL Group:" />
                                <ComboBox
                                    x:Name="cmbTLGroup"
                                    Grid.Column="1"
                                    Width="280"
                                    MinWidth="200"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="Value"
                                    ItemsSource="{Binding TLGroupOptions}"
                                    SelectedValuePath="Value" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!--  Mittleres Panel: UPN Template, Email & AD Settings  -->
                    <Border
                        Grid.Column="1"
                        Margin="0,0,10,10"
                        Background="WhiteSmoke"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        CornerRadius="5">
                        <StackPanel Margin="10">
                            <StackPanel Margin="5" Orientation="Vertical">
                                <TextBlock
                                    Margin="5"
                                    FontWeight="Bold"
                                    Text="UPN Template:" />
                                <!--  Eindeutiger Name für dieses Element  -->
                                <TextBlock
                                    x:Name="txtUPNTemplateDisplay"
                                    Width="302"
                                    MinWidth="200"
                                    Margin="5,-20,5,5"
                                    HorizontalAlignment="Right"
                                    Text="FIRSTNAME.LASTNAME@company.com" />
                                <Separator Margin="5,10,5,10" />
                            </StackPanel>
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Email Address:" />
                                <!--  Eindeutiger Name  -->
                                <TextBox
                                    x:Name="txtEmail"
                                    Grid.Column="1"
                                    MinWidth="200"
                                    Margin="41,0,0,0"
                                    VerticalAlignment="Center" />
                            </Grid>
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center"
                                    Text="Mail Suffix:" />
                                <!--  Eindeutiger Name  -->
                                <ComboBox
                                    x:Name="cmbSuffix"
                                    Grid.Column="1"
                                    MinWidth="200"
                                    Margin="60,0,0,0"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="Value"
                                    ItemsSource="{Binding MailSuffixListFromINI}"
                                    SelectedValuePath="Key" />
                            </Grid>
                            <Separator Margin="5,10,5,10" />
                            <!--  AD User Account Settings  -->
                            <StackPanel
                                Margin="5"
                                Background="#FFFBFBFB"
                                Orientation="Vertical">
                                <TextBlock FontWeight="Bold" Text="AD User Account Settings" />
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <CheckBox
                                        x:Name="chkAccountDisabled"
                                        Margin="5"
                                        Content="Account Disabled"
                                        IsChecked="True" />
                                    <CheckBox
                                        x:Name="chkPWNeverExpires"
                                        Margin="5"
                                        Content="Password Never Expires" />
                                </StackPanel>
                                <TextBlock
                                    Width="268"
                                    Height="16"
                                    Margin="-114,10,0,0"
                                    FontStyle="Italic"
                                    Text="Not effective when disabled!" />
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <CheckBox
                                        x:Name="chkSmartcardLogon"
                                        Margin="5"
                                        Content="Smartcard Logon" />
                                    <CheckBox
                                        x:Name="chkPreventPWChange"
                                        Margin="8,5,5,5"
                                        Content="Prevent Password Change" />
                                </StackPanel>
                                <CheckBox
                                    x:Name="chkPWChangeLogon"
                                    Margin="11,5,5,5"
                                    Content="Change Password at Logon" />
                            </StackPanel>
                            <Separator Margin="5,10,5,10" />
                            <!--  Password Options  -->
                            <StackPanel
                                Margin="5"
                                Background="#FFFBFBFB"
                                Orientation="Vertical">
                                <TextBlock FontWeight="Bold" Text="Password Options" />
                                <StackPanel Margin="57,-14,5,5" Orientation="Horizontal">
                                    <RadioButton
                                        x:Name="rbFix"
                                        Margin="100,-1,1,5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="FIXED" />
                                    <RadioButton
                                        x:Name="rbRand"
                                        Margin="13,-1,1,5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="GENERATED"
                                        IsChecked="True" />
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <TextBlock
                                        Margin="5"
                                        VerticalAlignment="Center"
                                        Text="Fixed Password:" />
                                    <TextBox
                                        x:Name="txtFixPW"
                                        Width="200"
                                        Margin="5"
                                        IsEnabled="False" />
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <TextBlock
                                        Margin="5,2,5,5"
                                        VerticalAlignment="Center"
                                        Text="Number of Characters:" />
                                    <TextBox
                                        x:Name="txtPWLen"
                                        Width="50"
                                        Margin="5,2,5,5"
                                        Text="14" />
                                </StackPanel>
                                <StackPanel Margin="5,-8,5,5" Orientation="Horizontal">
                                    <CheckBox
                                        x:Name="chkIncludeSpecial"
                                        Margin="5"
                                        Content="Special Characters" 
                                        IsChecked="True" />
                                    <CheckBox
                                        x:Name="chkAvoidAmbig"
                                        Margin="10,6,10,5"
                                        Content="Avoid Ambiguous Characters" 
                                        IsChecked="True" />
                                </StackPanel>
                            </StackPanel>
                            <Separator Margin="5,10,5,10" />
                            <!--  AD Groups Section  -->
                            <TextBlock Margin="5" FontWeight="Bold" Text="AD Groups:" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Height="172" Margin="5">
                                <ItemsControl x:Name="icADGroups">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                    <CheckBox Content="{Binding}" Margin="5"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!--  Rechtes Panel: Admin Buttons, Logo und Dokumentenoptionen (Namen bleiben unverändert)  -->
                    <Border
                        Grid.Column="2"
                        Margin="0,0,0,10"
                        Background="WhiteSmoke"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        CornerRadius="5">
                        <StackPanel Margin="10">
                            <!--  Logo und Header  -->
                            <StackPanel
                                Height="69"
                                HorizontalAlignment="Center"
                                Orientation="Vertical">
                                <StackPanel.Background>
                                    <ImageBrush ImageSource="C:\easyIT\DATA\easyONBOARDING-GUIICON-V2.png" />
                                </StackPanel.Background>
                                <Image
                                    x:Name="picLogo"
                                    Width="225"
                                    Height="61"
                                    Margin="0,0,0,10"
                                    Stretch="Fill" />
                            </StackPanel>
                            <!--  Admin Buttons  -->
                            <Border Height="174" Background="Transparent" />
                            <!--  Upload & Document Options  -->
                            <StackPanel
                                HorizontalAlignment="Center"
                                Background="#FFFBFBFB"
                                Orientation="Vertical">
                                <Button
                                    x:Name="btnUploadLogo"
                                    Width="180"
                                    Height="30"
                                    Margin="0,0,0,5"
                                    Content="Upload Onboarding LOGO" />
                                <TextBlock
                                    Margin="0,10,0,5"
                                    HorizontalAlignment="Center"
                                    FontWeight="Bold"
                                    Text="Select Onboarding Documents:" />
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <CheckBox
                                        x:Name="chkHTML"
                                        Margin="5"
                                        Content="HTML" 
                                        IsChecked="True" />
                                    <CheckBox
                                        x:Name="chkTXT"
                                        Margin="5"
                                        Content="TXT" />
                                </StackPanel>
                            </StackPanel>
                            <!--  Progress & Status  -->
                            <StackPanel
                                Margin="10"
                                HorizontalAlignment="Center"
                                Orientation="Vertical">
                                <ProgressBar
                                    x:Name="progressBar"
                                    Width="225"
                                    Height="20"
                                    Margin="0,23,0,5"
                                    Maximum="100"
                                    Minimum="0"
                                    Value="0" />
                                <TextBlock
                                    x:Name="lblStatus"
                                    HorizontalAlignment="Center"
                                    Text="Ready..." />
                            </StackPanel>
                            <!--  Onboard, PDF, Info, Close Buttons  -->
                            <StackPanel
                                Margin="10,10,10,10"
                                HorizontalAlignment="Center"
                                Background="#FFFBFBFB"
                                Orientation="Vertical">
                                <Button
                                    x:Name="btnOnboard"
                                    Width="225"
                                    Height="40"
                                    Margin="5"
                                    Background="LightGreen"
                                    Content="ONBOARDING" />
                                <Button
                                    x:Name="btnPDF"
                                    Width="225"
                                    Height="40"
                                    Margin="5"
                                    Background="LightYellow"
                                    Content="CREATE PDF" />
                                <Button
                                    x:Name="btnInfo"
                                    Width="225"
                                    Height="40"
                                    Margin="5"
                                    Background="LightBlue"
                                    Content="INFO" />
                                <Button
                                    x:Name="btnClose"
                                    Width="225"
                                    Height="40"
                                    Margin="5"
                                    Background="LightCoral"
                                    Content="CLOSE" />
                            </StackPanel>
                            <TextBlock
                                x:Name="lblFooter"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                FontSize="10"
                                Text="www.PSscripts.de" />
                        </StackPanel>
                    </Border>

                    <!--  Optional: Refresh Button für OU im Tab_Onboarding  -->
                    <Button
                        Grid.Row="1"
                        Width="88"
                        Height="46"
                        Margin="1053,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Content="REFRESH OUs" />
                </Grid>
            </TabItem>
            <!--  TAB 2: easyADUpdate (Platzhalter)  -->
            <TabItem x:Name="Tab_ADUpdate" Header="easyADUpdate">
                <Grid Margin="10">
                    <TextBlock
                        x:Name="lblPlaceholder"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        Text="Funktionalität in Arbeit..." />
                </Grid>
            </TabItem>

            <!--  TAB 3: easyADGroups  -->
            <TabItem x:Name="Tab_ADGroups" Header="easyADGroups">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Header Panel  -->
                    <Border
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        Background="#F0F0F0"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        CornerRadius="5">
                        <DockPanel Margin="5" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
                                <TextBlock
                                    x:Name="lblAppName_Grp"
                                    Margin="10,0,20,0"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="Black"
                                    Text="AD Gruppenmanager v0.2.6" />
                                <TextBlock
                                    x:Name="lblVersionInfo_Grp"
                                    Margin="10,6,0,0"
                                    FontSize="10"
                                    Text="Version: 0.2.6 | Last Update: 03.2025 | Author: Andreas Hepp" />
                            </StackPanel>
                            <Border
                                Margin="0,0,10,0"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                DockPanel.Dock="Right">
                                <Image
                                    x:Name="picLogoADGroups_Grp"
                                    Width="150"
                                    Height="60"
                                    Source="/easyADGroups-GUIICON-V1.png"
                                    Stretch="Fill">
                                    <Image.OpacityMask>
                                        <ImageBrush />
                                    </Image.OpacityMask>
                                </Image>
                            </Border>
                        </DockPanel>
                    </Border>

                    <!--  OU Panel  -->
                    <Border
                        Grid.Row="1"
                        Margin="0,0,133,10"
                        Background="WhiteSmoke"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        CornerRadius="5">
                        <StackPanel Margin="10,10,20,10">
                            <TextBlock FontWeight="Bold" Text="OU-Filter:" />
                            <TextBox
                                x:Name="txtOUFilter_Grp"
                                Width="600"
                                Margin="0,5,0,10" />
                            <ComboBox
                                x:Name="comboBoxOU_Grp"
                                Width="600"
                                Height="25"
                                Margin="0,0,0,10"
                                DisplayMemberPath="Name"
                                SelectedValuePath="DN" />
                        </StackPanel>
                    </Border>

                    <!--  Group Creation Panel  -->
                    <Border
                        Grid.Row="2"
                        Background="WhiteSmoke"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        CornerRadius="5">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!--  Linke Spalte: Gruppendaten  -->
                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="5">
                                <TextBlock
                                    Margin="0,0,0,5"
                                    FontWeight="Bold"
                                    Text="Name der Gruppe:" />
                                <TextBox
                                    x:Name="textBoxPrefix_Grp"
                                    Width="338"
                                    Margin="0,-19,0,10" />
                                <TextBlock FontWeight="Bold" Text="Trenner:" />
                                <TextBox
                                    x:Name="textBoxSeparator_Grp"
                                    Width="139"
                                    Margin="-199,-14.4,0,10"
                                    Text="-" />
                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <StackPanel Margin="0,0,20,0" Orientation="Vertical">
                                        <TextBlock FontWeight="Bold" Text="Startnummer:" />
                                        <TextBox
                                            x:Name="textBoxStart_Grp"
                                            Width="80"
                                            Margin="0,10,0,-1" />
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock FontWeight="Bold" Text="Endnummer:" />
                                        <TextBox
                                            x:Name="textBoxEnd_Grp"
                                            Width="80"
                                            Margin="0,10,0,-1" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock FontWeight="Bold" Text="Beschreibung:" />
                                <TextBox
                                    x:Name="textBoxDescription_Grp"
                                    Width="375"
                                    Margin="0,-14,0,10" />
                                <TextBlock FontWeight="Bold" Text="E-Mail:" />
                                <TextBox
                                    x:Name="textBoxEmail_Grp"
                                    Width="375"
                                    Margin="0,-15,0,10" />
                            </StackPanel>
                            <!--  Rechte Spalte: Einstellungen  -->
                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="5">
                                <CheckBox
                                    x:Name="checkHideGAL_Grp"
                                    Margin="0,0,0,5"
                                    Content="Hide from GAL" />
                                <CheckBox
                                    x:Name="checkMailEnabled_Grp"
                                    Margin="0,0,0,5"
                                    Content="Mail-enabled Security" />
                                <CheckBox
                                    x:Name="checkSendAs_Grp"
                                    Margin="0,0,0,10"
                                    Content="Enable SendAs" />
                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,7,10,0"
                                        FontWeight="Bold"
                                        Text="Gruppentyp:" />
                                    <RadioButton
                                        x:Name="radioSecurity_Grp"
                                        Margin="0,10,10,0"
                                        Background="{x:Null}"
                                        Content="Security"
                                        IsChecked="True" />
                                    <RadioButton
                                        x:Name="radioDistribution_Grp"
                                        Margin="0,10,0,0"
                                        Content="Distribution" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,-3,10,0"
                                        FontWeight="Bold"
                                        Text="Scope:" />
                                    <RadioButton
                                        x:Name="radioGlobal_Grp"
                                        Margin="0,0,1,0"
                                        Content="Global"
                                        IsChecked="True" />
                                    <RadioButton
                                        x:Name="radioUniversal_Grp"
                                        Margin="0,0,1,0"
                                        Content="Universal" />
                                    <RadioButton
                                        x:Name="radioDomainLocal_Grp"
                                        Margin="0,0,1,0"
                                        Content="DomainLocal" />
                                </StackPanel>
                                <CheckBox
                                    x:Name="chkSpecial_Grp"
                                    Margin="0,35,0,0"
                                    Content="JIRA / Confluence Gruppe(n) erstellen (Suffix aus INI)" />
                            </StackPanel>
                            <!--  Zeile 2: Label Mitglieder  -->
                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Margin="5"
                                Orientation="Vertical">
                                <TextBlock
                                    Margin="0,0,0,5"
                                    FontWeight="Bold"
                                    Text="Mitglieder:" />
                            </StackPanel>
                            <!--  Zeile 3: ListBox für Mitglieder  -->
                            <ListBox
                                x:Name="listBoxUsers_Grp"
                                Grid.Row="3"
                                Grid.RowSpan="2"
                                Grid.Column="0"
                                Height="194"
                                Margin="10,5,10,0"
                                VerticalAlignment="Top"
                                DisplayMemberPath="DisplayName"
                                SelectionMode="Extended" />
                        </Grid>
                    </Border>

                    <!--  Zeile 4: Vorschau und Erstellen Buttons  -->
                    <StackPanel
                        Grid.Row="3"
                        Margin="5"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                        <Button
                            x:Name="buttonPreview_Grp"
                            Width="90"
                            Margin="5"
                            Background="LightBlue"
                            Content="Vorschau" />
                        <Button
                            x:Name="buttonCreate_Grp"
                            Width="90"
                            Margin="5"
                            Background="LightGreen"
                            Content="Erstellen" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!--  TAB 4: Settings  -->
            <TabItem x:Name="Tab_Settings" Header="Settings">
                <Grid Height="733">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!--  Liste der INI-Sektionen  -->
                    <ListView
                        x:Name="listViewSections_Settings"
                        Grid.Column="0"
                        Margin="5,5,5,89"
                        SelectionMode="Single">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn
                                    Width="280"
                                    DisplayMemberBinding="{Binding SectionName}"
                                    Header="Abschnitt" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <!--  DataGrid für Einstellungen  -->
                    <DataGrid
                        x:Name="dataGridSettings_Settings"
                        Grid.Column="1"
                        Margin="5,5,5,89"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="150"
                                Binding="{Binding Key}"
                                Header="Key" />
                            <DataGridTextColumn
                                Width="400"
                                Binding="{Binding Value}"
                                Header="Value" />
                            <DataGridTextColumn
                                Width="285"
                                Binding="{Binding Comment}"
                                Header="Comment"
                                IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <!--  Buttons für Settings  -->
                    <StackPanel
                        Width="295"
                        Margin="5,653,0,30"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                        <Button
                            x:Name="btnSaveChanges_Settings"
                            Width="111"
                            Height="40"
                            Background="LightGreen"
                            Content="Save Changes" />
                        <Button
                            x:Name="btnInfoSettings_Settings"
                            Width="65"
                            Height="40"
                            Margin="5"
                            Background="LightBlue"
                            Content="Info" />
                        <Button
                            x:Name="btnCloseSettings_Settings"
                            Width="98"
                            Height="40"
                            Margin="5"
                            Background="LightCoral"
                            Content="Close" />
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>